{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Type-checking */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* JS interop — only .ts files are type-checked; .js files are inferred */
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "src/services/pokeApi.ts",
    "src/services/visionSimulator.ts",
    "src/services/pokemonAssistant.ts",
    "src/services/pokemonKnowledge.ts",
    "src/services/pokemonAiChat.ts",
    "src/hooks/useLocalStorage.ts",
    "src/hooks/useFocusTrap.ts",
    "src/hooks/useImagePreview.ts",
    "src/hooks/usePwaInstall.ts",
    "src/hooks/useAchievements.ts",
    "src/hooks/useCollection.ts",
    "src/hooks/usePokemonFetch.ts"
  ],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
